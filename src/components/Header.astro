---
import { site } from "../data/site";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="site-header">
  <nav class="container nav" aria-label="Primary navigation">
    <a class="brand" href="/" aria-label="Shiqing Gao home">
      <span class="brand-mark" aria-hidden="true">SG</span>
      <span class="brand-copy">
        <strong>Shiqing Gao</strong>
        <small>Projects · Writing · Explorations</small>
      </span>
    </a>
    <div class="nav-links">
      {
        site.navigation.map((item) => {
          const itemPath = item.href.replace(/\/$/, "") || "/";
          const isCurrent =
            currentPath === itemPath ||
            (item.href !== "/" && currentPath.startsWith(itemPath));

          return (
            <a href={item.href} aria-current={isCurrent ? "page" : undefined}>
              {item.label}
            </a>
          );
        })
      }
    </div>
  </nav>
</header>
