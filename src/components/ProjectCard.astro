---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const projectUrl = `/projects/${project.slug}`;
---

<article class="project-card">
  <div class="project-card-topline">
    <span>{project.data.category}</span>
    <span>{project.data.status}</span>
  </div>
  <div>
    <h3><a href={projectUrl}>{project.data.title}</a></h3>
    {project.data.titleZh && <p class="project-title-zh">{project.data.titleZh}</p>}
  </div>
  <p>{project.data.summary}</p>
  <div class="tag-list" aria-label="Project tags">
    {project.data.tags.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
  </div>
  <footer>
    <a class="text-link" href={projectUrl}>View project / 查看项目 <span aria-hidden="true">→</span></a>
  </footer>
</article>
