---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const projectUrl = `/projects/${project.slug}`;
const repoUrl = project.data.repoUrl;
---

<article class="project-card">
  <div class="project-card-topline">
    <span>{project.data.category}</span>
    <span>{project.data.status}</span>
  </div>
  <div>
    <h3><a href={projectUrl}>{project.data.title}</a></h3>
  </div>
  <p>{project.data.summary}</p>
  <div class="tag-list" aria-label="Project tags">
    {project.data.tags.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
  </div>
  <footer>
    <a class="text-link" href={projectUrl}>View project <span aria-hidden="true">-&gt;</span></a>
    {repoUrl && <a class="text-link secondary-project-link" href={repoUrl}>GitHub <span aria-hidden="true">-&gt;</span></a>}
  </footer>
</article>
