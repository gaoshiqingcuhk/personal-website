---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found | Shiqing Gao" description="The requested page could not be found." noindex>
  <section class="container not-found">
    <p class="eyebrow">404 / 没找到</p>
    <h1>这个页面暂时不在这里。</h1>
    <p>The link may have moved, or the page may still be taking shape.</p>
    <a class="button primary" href="/">Back home / 返回首页</a>
  </section>
</BaseLayout>
