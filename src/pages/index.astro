---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { profile } from "../data/profile";
import { site } from "../data/site";
import { sortProjectsByDate } from "../utils/projects";

const allProjects = sortProjectsByDate(await getCollection("projects"));
const featuredProjects = allProjects.filter((project) => project.data.featured).slice(0, 4);

const entries = [
  {
    href: "/projects",
    number: "01",
    title: "Projects",
    copy: "Selected computational projects in inverse problems, UQ, and modeling."
  },
  {
    href: "/cv",
    number: "02",
    title: "CV",
    copy: "Education, interests, projects, coursework, and technical skills."
  },
  {
    href: profile.github,
    number: "03",
    title: "GitHub",
    copy: "Public code and small computational experiments."
  },
  {
    href: "/contact",
    number: "04",
    title: "Contact",
    copy: "Email, GitHub, and website information."
  }
];
---

<BaseLayout title={site.title} description={site.description} lang="en">
  <section class="container home-hero">
    <div class="home-hero-copy">
      <p class="eyebrow">Undergraduate mathematics student</p>
      <h1>Shiqing <span>Gao.</span></h1>
      <p class="hero-zh">
        Undergraduate student in Mathematics, The Chinese University of Hong Kong.
      </p>
      <p class="hero-copy">
        I am interested in applied mathematics, computational inverse problems,
        scientific computing, numerical methods, uncertainty quantification, and
        machine learning-related inverse problems. This site collects selected
        undergraduate computational projects and a concise academic CV.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/projects">View Projects</a>
        <a class="button secondary" href="/cv">View CV</a>
        <a class="button secondary" href={profile.github}>GitHub</a>
        <a class="button quiet" href="/contact">Contact</a>
      </div>
    </div>
    <aside class="identity-visual" aria-label="Shiqing Gao profile summary">
      <div class="identity-mark" aria-hidden="true">SG</div>
      <div class="identity-lines" aria-hidden="true"><span></span><span></span><span></span></div>
      <p>Current focus</p>
      <strong>Inverse problems, scientific computing, and UQ</strong>
      <small>Learning through small reproducible numerical experiments.</small>
    </aside>
  </section>

  <section class="container home-entries" aria-label="Main links">
    {entries.map((entry) => (
      <a class="entry-card" href={entry.href}>
        <span class="entry-number">{entry.number}</span>
        <h2>{entry.title}</h2>
        <p>{entry.copy}</p>
        <span class="entry-arrow" aria-hidden="true">-&gt;</span>
      </a>
    ))}
  </section>

  <section class="section section-band">
    <div class="container section-heading">
      <div>
        <p class="eyebrow">Selected work</p>
        <h2>Selected computational projects</h2>
      </div>
      <p>
        These are modest undergraduate computational projects. Each page records
        the problem, methods, outputs, and limitations in a concise public format.
      </p>
    </div>
    <div class="container grid project-grid">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="container home-writing section">
    <div>
      <p class="eyebrow">Notes and personal space</p>
      <h2>Secondary pages, kept intentionally low-key.</h2>
    </div>
    <div>
      <p>
        I keep a small writing area and a life/interests page for learning notes
        and personal context. They stay secondary to the project pages, but help
        keep the site personal and maintained.
      </p>
      <a class="text-link" href="/writing">Visit writing <span aria-hidden="true">-&gt;</span></a>
      <span class="secondary-separator" aria-hidden="true">/</span>
      <a class="text-link" href="/life">Visit life page <span aria-hidden="true">-&gt;</span></a>
    </div>
  </section>

  <section class="container home-closing">
    <p>
      The site is a concise record of what I am currently learning by building,
      testing, and writing down small computational projects.
    </p>
  </section>
</BaseLayout>
