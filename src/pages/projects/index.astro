---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getAllTags, sortProjectsByDate } from "../../utils/projects";

const projects = sortProjectsByDate(await getCollection("projects"));
const tags = getAllTags(projects);
---

<BaseLayout title="Projects | Your Name">
  <header class="container page-header">
    <p class="eyebrow">Projects</p>
    <h1>Project archive</h1>
    <p>
      A growing collection of applied mathematics, modeling, statistics,
      imaging, data analysis, and computing projects.
    </p>
  </header>

  <section class="container">
    <div class="tag-filter" aria-label="Available project tags">
      <div class="tag-list">
        {tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
    </div>
    <div class="grid project-grid">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</BaseLayout>
