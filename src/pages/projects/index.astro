---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { sortProjectsByDate } from "../../utils/projects";

const projects = sortProjectsByDate(await getCollection("projects"));
const categories = ["Academic / Technical", "Meta", "Creative / Personal"] as const;
---

<BaseLayout
  title="Projects | Shiqing Gao"
  description="Selected undergraduate computational projects by Shiqing Gao in inverse problems, subdiffusion visualization, uncertainty quantification, modeling, and optimization."
  lang="en"
>
  <header class="container page-header personal-header">
    <p class="eyebrow">Projects</p>
    <h1>Selected undergraduate computational projects.</h1>
    <p>
      This page collects selected projects in applied mathematics, computational
      inverse problems, scientific computing, uncertainty quantification, and
      modeling. The descriptions are intentionally modest and focus on what was
      implemented, evaluated, and documented.
    </p>
  </header>

  <div class="container category-stack">
    {
      categories.map((category) => {
        const items = projects.filter((project) => project.data.category === category);
        if (items.length === 0) return null;

        return (
          <section class="project-category">
            <div class="category-heading">
              <h2>{category}</h2>
              <span>{items.length.toString().padStart(2, "0")}</span>
            </div>
            <div class="grid project-grid">
              {items.map((project) => <ProjectCard project={project} />)}
            </div>
          </section>
        );
      })
    }
  </div>
</BaseLayout>
