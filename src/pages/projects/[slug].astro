---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({ params: { slug: project.slug }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const links = [
  project.data.repoUrl && { label: "Repository", href: project.data.repoUrl },
  project.data.demoUrl && { label: "Live site", href: project.data.demoUrl },
  project.data.reportUrl && { label: "Report", href: project.data.reportUrl }
].filter(Boolean);
---

<BaseLayout title={`${project.data.title} | Shiqing Gao`} description={project.data.summary} lang="en">
  <header class="container project-header">
    <a class="back-link" href="/projects">&lt;- All projects</a>
    <div class="project-header-grid">
      <div>
        <p class="eyebrow">{project.data.category}</p>
        <h1>{project.data.title}</h1>
        <p class="project-summary">{project.data.summary}</p>
      </div>
      <dl class="project-facts">
        <div><dt>Status</dt><dd>{project.data.status}</dd></div>
        <div><dt>Role</dt><dd>{project.data.role}</dd></div>
        <div><dt>Tools</dt><dd>{project.data.tools.join(", ")}</dd></div>
      </dl>
    </div>
  </header>

  <div class="container project-body-grid">
    <article class="prose project-prose"><Content /></article>
    <aside class="project-aside">
      <div class="tag-list" aria-label="Project tags">
        {project.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
      </div>
      {links.length > 0 && (
        <div class="project-links">
          {links.map((link: any) => <a href={link.href}>{link.label} <span aria-hidden="true">-&gt;</span></a>)}
        </div>
      )}
    </aside>
  </div>
</BaseLayout>
