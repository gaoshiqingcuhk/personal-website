---
import { cv } from "../../data/cv";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{cv.name} CV</title>
    <style>
      @page {
        size: A4;
        margin: 14mm 15mm;
      }

      :root {
        --text: #1d2526;
        --muted: #536164;
        --line: #cfd6d3;
        --accent: #184f57;
        --soft: #edf3f2;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        color: var(--text);
        background: #fff;
        font-size: 10.5pt;
        line-height: 1.42;
        print-color-adjust: exact;
        -webkit-print-color-adjust: exact;
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      h1,
      h2,
      h3,
      p {
        margin: 0;
      }

      h1 {
        font-size: 26pt;
        line-height: 1;
        letter-spacing: 0;
      }

      h2 {
        border-bottom: 1px solid var(--line);
        color: var(--accent);
        font-size: 10.5pt;
        letter-spacing: 0.08em;
        margin-bottom: 5pt;
        padding-bottom: 3pt;
        text-transform: uppercase;
      }

      h3 {
        font-size: 11.2pt;
        margin-bottom: 2pt;
      }

      ul {
        margin: 4pt 0 0 14pt;
        padding: 0;
      }

      li {
        margin: 1.5pt 0;
      }

      .print-shell {
        width: 100%;
      }

      .print-header {
        border-bottom: 2px solid var(--accent);
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 16pt;
        margin-bottom: 13pt;
        padding-bottom: 9pt;
      }

      .print-title {
        color: var(--muted);
        font-size: 12pt;
        margin-top: 4pt;
      }

      .print-contact {
        color: var(--muted);
        font-size: 9.4pt;
        line-height: 1.38;
        text-align: right;
      }

      .print-section {
        break-inside: avoid;
        margin-top: 10pt;
        page-break-inside: avoid;
      }

      .print-entry {
        break-inside: avoid;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 12pt;
        page-break-inside: avoid;
      }

      .print-meta {
        color: var(--muted);
        text-align: right;
        white-space: nowrap;
      }

      .interest-list,
      .course-list {
        display: flex;
        flex-wrap: wrap;
        gap: 4pt;
        list-style: none;
        margin: 0;
      }

      .interest-list li,
      .course-list li {
        background: var(--soft);
        border: 1px solid var(--line);
        border-radius: 999px;
        margin: 0;
        padding: 2pt 6pt;
      }

      .project {
        break-inside: avoid;
        margin-top: 7pt;
        page-break-inside: avoid;
      }

      .project:first-of-type {
        margin-top: 0;
      }

      .tools,
      .todo {
        color: var(--muted);
        margin-top: 3pt;
      }

      .skills {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5pt 14pt;
      }

      .skill-group {
        break-inside: avoid;
        page-break-inside: avoid;
      }

      .skill-group strong {
        color: var(--accent);
      }

      @media print {
        .print-section,
        .project,
        .skill-group,
        .print-entry {
          break-inside: avoid;
          page-break-inside: avoid;
        }
      }
    </style>
  </head>
  <body>
    <main class="print-shell">
      <header class="print-header">
        <div>
          <h1>{cv.name}</h1>
          <p class="print-title">{cv.title}</p>
        </div>
        <div class="print-contact">
          <div>{cv.location}</div>
          <div>{cv.email}</div>
          <div>{cv.website}</div>
          <div>{cv.github}</div>
          <div>{cv.linkedin}</div>
        </div>
      </header>

      <section class="print-section">
        <h2>Education</h2>
        {
          cv.education.map((item) => (
            <article class="print-entry">
              <div>
                <h3>{item.institution}</h3>
                <p>{item.degree}</p>
              </div>
              <p class="print-meta">
                {item.standing}
                {item.showGpa && item.gpa ? ` · GPA: ${item.gpa}` : ""}
              </p>
            </article>
          ))
        }
      </section>

      <section class="print-section">
        <h2>Research Interests</h2>
        <ul class="interest-list">
          {cv.interests.map((interest) => <li>{interest}</li>)}
        </ul>
      </section>

      <section class="print-section">
        <h2>Projects</h2>
        {
          cv.projects.map((project) => (
            <article class="project">
              <h3>{project.name}</h3>
              <ul>
                {project.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
              <p class="tools">
                <strong>Tools:</strong> {project.tools.join(", ")}
              </p>
              {project.note && <p class="todo">{project.note}</p>}
            </article>
          ))
        }
      </section>

      <section class="print-section">
        <h2>Technical Skills</h2>
        <div class="skills">
          {
            cv.skills.map((group) => (
              <p class="skill-group">
                <strong>{group.category}:</strong> {group.items.join(", ")}
              </p>
            ))
          }
        </div>
      </section>

      <section class="print-section">
        <h2>Coursework</h2>
        <ul class="course-list">
          {cv.coursework.map((course) => <li>{course}</li>)}
        </ul>
      </section>

      <section class="print-section">
        <h2>Awards / Activities</h2>
        <ul>
          {cv.awardsActivities.map((item) => <li>{item}</li>)}
        </ul>
      </section>
    </main>
  </body>
</html>
