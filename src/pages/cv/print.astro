---
import { cv } from "../../data/cv";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>{cv.name} CV</title>
    <style>
      @page { size: A4; margin: 12mm 14mm; }
      :root {
        --text: #182122;
        --muted: #536164;
        --line: #cbd4d2;
        --accent: #184f57;
        --soft: #edf3f2;
        font-family: Arial, "Helvetica Neue", sans-serif;
      }
      * { box-sizing: border-box; }
      html, body {
        margin: 0;
        color: var(--text);
        background: #fff;
        font-size: 9.4pt;
        line-height: 1.32;
        print-color-adjust: exact;
        -webkit-print-color-adjust: exact;
      }
      a { color: var(--accent); text-decoration: none; }
      h1, h2, h3, p { margin: 0; }
      h1 { font-size: 24pt; line-height: 1; }
      h2 {
        border-bottom: 1px solid var(--line);
        color: var(--accent);
        font-size: 9.8pt;
        letter-spacing: 0.08em;
        margin-bottom: 4pt;
        padding-bottom: 2.5pt;
        text-transform: uppercase;
      }
      h3 { font-size: 10.2pt; margin-bottom: 1.5pt; }
      ul { margin: 3pt 0 0 13pt; padding: 0; }
      li { margin: 0.8pt 0; }
      .print-header {
        border-bottom: 2px solid var(--accent);
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 14pt;
        margin-bottom: 8pt;
        padding-bottom: 7pt;
      }
      .print-title { color: var(--muted); font-size: 11pt; margin-top: 3pt; }
      .print-contact { color: var(--muted); font-size: 8.7pt; line-height: 1.35; text-align: right; }
      .print-section { break-inside: avoid; margin-top: 6pt; page-break-inside: avoid; }
      .print-entry { display: grid; grid-template-columns: 1fr auto; gap: 10pt; }
      .print-meta { color: var(--muted); text-align: right; white-space: nowrap; }
      .interest-list, .course-list {
        display: flex;
        flex-wrap: wrap;
        gap: 3pt;
        list-style: none;
        margin: 0;
      }
      .interest-list li, .course-list li {
        background: var(--soft);
        border: 1px solid var(--line);
        border-radius: 99px;
        margin: 0;
        padding: 1.5pt 5pt;
      }
      .project { break-inside: avoid; margin-top: 4.5pt; page-break-inside: avoid; }
      .project:first-of-type { margin-top: 0; }
      .tools { color: var(--muted); margin-top: 2pt; }
      .skills { display: grid; grid-template-columns: 1fr 1fr; gap: 3pt 12pt; }
      .skill-group { break-inside: avoid; }
      .skill-group strong { color: var(--accent); }
      @media print {
        .print-section, .project, .skill-group, .print-entry { break-inside: avoid; page-break-inside: avoid; }
        h2, h3 { break-after: avoid; page-break-after: avoid; }
      }
    </style>
  </head>
  <body>
    <main>
      <header class="print-header">
        <div><h1>{cv.name}</h1><p class="print-title">{cv.title}</p></div>
        <div class="print-contact">
          <div>{cv.location}</div>
          <div>{cv.emailLabel}</div>
          <div><a href={cv.github}>github.com/gaoshiqingcuhk</a></div>
          <div><a href={cv.website}>www.gaoshiqing.space</a></div>
        </div>
      </header>

      <section class="print-section">
        <h2>Education</h2>
        {cv.education.map((item) => (
          <article class="print-entry">
            <div><h3>{item.institution}</h3><p>{item.degree}</p></div>
          </article>
        ))}
      </section>

      <section class="print-section">
        <h2>Research Interests</h2>
        <ul class="interest-list">{cv.interests.map((interest) => <li>{interest}</li>)}</ul>
      </section>

      <section class="print-section">
        <h2>Selected Projects</h2>
        {cv.projects.map((project) => (
          <article class="project">
            <h3>{project.url ? <a href={new URL(project.url, cv.website)}>{project.name}</a> : project.name}</h3>
            <ul>{project.bullets.map((bullet) => <li>{bullet}</li>)}</ul>
            <p class="tools"><strong>Tools:</strong> {project.tools.join(", ")}</p>
          </article>
        ))}
      </section>

      <section class="print-section">
        <h2>Technical Skills</h2>
        <div class="skills">{cv.skills.map((group) => (
          <p class="skill-group"><strong>{group.category}:</strong> {group.items.join(", ")}</p>
        ))}</div>
      </section>

      <section class="print-section">
        <h2>Coursework</h2>
        <ul class="course-list">{cv.coursework.map((course) => <li>{course}</li>)}</ul>
      </section>

      {cv.awardsActivities.length > 0 && (
        <section class="print-section">
          <h2>Awards / Activities</h2>
          <ul>{cv.awardsActivities.map((item) => <li>{item}</li>)}</ul>
        </section>
      )}
    </main>
  </body>
</html>
