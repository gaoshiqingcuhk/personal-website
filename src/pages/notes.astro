---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Notes | Your Name">
  <header class="container page-header">
    <p class="eyebrow">Notes</p>
    <h1>Reading and learning notes</h1>
    <p>
      A future home for short mathematical explanations, reading summaries,
      course reflections, and experiment logs.
    </p>
  </header>

  <section class="container section grid">
    <article class="note-card">
      <h2>Coming Soon</h2>
      <p>
        This section can later be powered by another content collection, such as
        `src/content/notes`, using the same pattern as projects.
      </p>
    </article>
  </section>
</BaseLayout>
